rules_version = '2';

// ================================================================
// 약속의 땅 청년부 앱 — Firestore Security Rules
// ================================================================
//
// 유저 역할 체계:
//   • 비로그인 / pending → 모든 컬렉션 접근 불가
//   • active 일반 유저  → 공개 콘텐츠 읽기, 본인 정보 제한 수정
//   • active admin 유저 → 전체 읽기·쓰기·삭제
//
// 컬렉션 목록:
//   users, cells, rosters, notices (+ /comments), bulletins,
//   worshipSets, events, cellMeetings, serviceSchedules,
//   attendance, offering, notifications, meta
// ================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ────────────────────────────────────────────────────────────
    // 헬퍼 함수
    // ────────────────────────────────────────────────────────────

    // Firebase Auth 토큰 존재 여부
    function isAuthed() {
      return request.auth != null;
    }

    // Firestore에서 현재 유저 문서 읽기 (캐시됨 — 동일 요청 내 1회 과금)
    function meDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // 유저 문서가 존재하는지 확인
    function meExists() {
      return isAuthed() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // status == 'active' 인 로그인 유저
    function isActive() {
      return meExists() && meDoc().data.status == 'active';
    }

    // role == 'admin' && status == 'active'
    function isAdmin() {
      return isActive() && meDoc().data.role == 'admin';
    }

    // ────────────────────────────────────────────────────────────
    // users — 회원 정보 (uid, name, phone, birth, role, status 등)
    // ────────────────────────────────────────────────────────────
    match /users/{uid} {

      // 목록 조회(list): 활성 유저만 (앱의 listenCol('users') 사용)
      // pending / 비로그인 차단
      allow list: if isActive();

      // 단건 조회(get): 본인 문서 OR 관리자
      allow get: if (isAuthed() && request.auth.uid == uid) || isAdmin();

      // 신규 가입 생성: 본인 UID, role='user', status='pending' 강제
      allow create: if isAuthed()
        && request.auth.uid == uid
        && request.resource.data.role == 'user'
        && request.resource.data.status == 'pending';

      // 본인 수정:
      //   - role 변경 불가 (admin 자가 취득 차단)
      //   - status는 유지 또는 'active' → 'withdraw_pending' 으로만 변경 가능
      //   - 관리자는 모든 필드 수정 가능
      allow update: if isAdmin()
        || (isAuthed() && request.auth.uid == uid && isActive()
            && request.resource.data.role == resource.data.role
            && (request.resource.data.status == resource.data.status
                || (request.resource.data.status == 'withdraw_pending'
                    && resource.data.status == 'active')));

      // 삭제: 관리자만 (탈퇴 처리)
      allow delete: if isAdmin();
    }

    // ────────────────────────────────────────────────────────────
    // cells — 목장 정보 (이름, 목자, 순서)
    // ────────────────────────────────────────────────────────────
    match /cells/{cellId} {
      allow read:   if isActive();
      allow write:  if isAdmin();
    }

    // ────────────────────────────────────────────────────────────
    // rosters — 명부 (이름, 전화번호, 생년월일 등 개인정보 포함)
    // ────────────────────────────────────────────────────────────
    match /rosters/{rosterId} {
      // 앱 전체 기능(출석·목장 탭 등)에 명부 조회가 필요
      allow read:   if isActive();
      // 추가·수정·삭제는 관리자만
      allow write:  if isAdmin();
    }

    // ────────────────────────────────────────────────────────────
    // notices — 공지사항
    // ────────────────────────────────────────────────────────────
    match /notices/{noticeId} {
      allow read:   if isActive();
      allow write:  if isAdmin();

      // /notices/{noticeId}/comments — 댓글
      match /comments/{commentId} {
        allow read: if isActive();

        // 활성 유저: 본인 uid 필드가 일치하는 댓글만 생성 가능
        // 허용 필드: id, uid, name, body, at (추가 필드 삽입 차단)
        allow create: if isActive()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.keys().hasAll(['id', 'uid', 'name', 'body', 'at'])
          && request.resource.data.keys().hasOnly(['id', 'uid', 'name', 'body', 'at', 'createdAt']);

        // 수정·삭제: 관리자만
        allow update, delete: if isAdmin();
      }
    }

    // ────────────────────────────────────────────────────────────
    // bulletins — 주보
    // ────────────────────────────────────────────────────────────
    match /bulletins/{bulletinId} {
      allow read:   if isActive();
      allow write:  if isAdmin();
    }

    // ────────────────────────────────────────────────────────────
    // worshipSets — 찬양 세트
    // ────────────────────────────────────────────────────────────
    match /worshipSets/{wsId} {
      allow read:   if isActive();
      allow write:  if isAdmin();
    }

    // ────────────────────────────────────────────────────────────
    // events — 일정
    // ────────────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read:   if isActive();
      allow write:  if isAdmin();
    }

    // ────────────────────────────────────────────────────────────
    // cellMeetings — 목장 나눔 자료 (말씀·나눔질문·기도제목)
    // ────────────────────────────────────────────────────────────
    match /cellMeetings/{meetingId} {
      allow read:   if isActive();
      allow write:  if isAdmin();
    }

    // ────────────────────────────────────────────────────────────
    // serviceSchedules — 임사 (예배 담당자)
    // ────────────────────────────────────────────────────────────
    match /serviceSchedules/{scheduleId} {
      // 홈 화면 '금주 예배 담당' 섹션에서 일반 유저도 조회
      allow read:   if isActive();
      allow write:  if isAdmin();
    }

    // ────────────────────────────────────────────────────────────
    // attendance — 출석 기록 (민감 통계 데이터 — 관리자 전용)
    // ────────────────────────────────────────────────────────────
    match /attendance/{dateId} {
      allow read, write: if isAdmin();
    }

    // ────────────────────────────────────────────────────────────
    // offering — 헌금 기록 (재정 데이터 — 관리자 전용)
    // ────────────────────────────────────────────────────────────
    match /offering/{dateId} {
      allow read, write: if isAdmin();
    }

    // ────────────────────────────────────────────────────────────
    // notifications — 알림 발송 기록 (쓰기: 관리자 / 읽기 불필요)
    // ────────────────────────────────────────────────────────────
    match /notifications/{notiId} {
      allow write: if isAdmin();
      // 앱에서 읽지 않으므로 read 차단 (필요 시 isAdmin()으로 제한 완화 가능)
      allow read:  if isAdmin();
    }

    // ────────────────────────────────────────────────────────────
    // meta — 내부 메타 (시드 완료 여부 등)
    // ────────────────────────────────────────────────────────────
    match /meta/{metaId} {
      // seedIfNeeded()가 인증 후 백그라운드 실행 → 인증된 유저 읽기 허용
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }

    // ────────────────────────────────────────────────────────────
    // 기타 모든 경로: 명시적 차단 (화이트리스트 방식)
    // ────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
